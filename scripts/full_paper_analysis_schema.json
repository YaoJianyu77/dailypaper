{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "abstract_translation_zh",
    "background_zh",
    "problem_zh",
    "method_overview_zh",
    "method_details",
    "experiment_setup_zh",
    "datasets_or_benchmarks",
    "baselines",
    "metrics",
    "ablation_or_analysis",
    "evaluation_validity",
    "main_results_zh",
    "strengths",
    "limitations",
    "technical_route_zh",
    "relation_to_prior_work_zh",
    "related_work_comparisons",
    "score_card",
    "practical_value_zh",
    "future_work",
    "reading_checklist",
    "overall_assessment_zh"
  ],
  "properties": {
    "paper_id": {
      "type": "string"
    },
    "abstract_translation_zh": {
      "type": "string"
    },
    "background_zh": {
      "type": "string"
    },
    "problem_zh": {
      "type": "string"
    },
    "method_overview_zh": {
      "type": "string"
    },
    "method_details": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 5
    },
    "experiment_setup_zh": {
      "type": "string"
    },
    "datasets_or_benchmarks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 6
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 6
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 6
    },
    "ablation_or_analysis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "evaluation_validity": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "main_results_zh": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "technical_route_zh": {
      "type": "string"
    },
    "relation_to_prior_work_zh": {
      "type": "string"
    },
    "related_work_comparisons": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "paper_id",
          "title",
          "relation",
          "comparison_zh"
        ],
        "properties": {
          "paper_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          },
          "comparison_zh": {
            "type": "string"
          }
        }
      }
    },
    "score_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "innovation",
        "technical_quality",
        "experimental_rigor",
        "writing_clarity",
        "practical_value"
      ],
      "properties": {
        "innovation": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "technical_quality": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "experimental_rigor": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "writing_clarity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "practical_value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "practical_value_zh": {
      "type": "string"
    },
    "future_work": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "reading_checklist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "overall_assessment_zh": {
      "type": "string"
    }
  }
}
