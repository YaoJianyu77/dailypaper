        "type": "string"
      },
      "maxItems": 5
    },
    "experiment_setup_zh": {
      "type": "string"
    },
    "main_results_zh": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "relation_to_prior_work_zh": {
      "type": "string"
    },
    "practical_value_zh": {
      "type": "string"
    },
    "future_work": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "reading_checklist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "overall_assessment_zh": {
      "type": "string"
    }
  }
